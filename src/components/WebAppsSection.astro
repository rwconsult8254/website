---
const webapps = [
    {
        title: "Tank Dynamics Simulator",
        description:
            "Real-time PID-controlled tank model with level, flow, and disturbance response. C++ physics engine, WebSocket streaming.",
        href: "/projects",
    },
];
---

<section id="webapps" class="webapps">
    <div class="section-header">
        <h2>Interactive Tools</h2>
        <span class="tag">Live</span>
    </div>
    <p class="subtitle">
        Browser-based engineering simulations — no login required.
    </p>

    <div class="grid">
        {
            webapps.map((app) => (
                <a class="card" href={app.href}>
                    <h3>{app.title}</h3>
                    <p>{app.description}</p>
                    <span class="link">Launch Demo →</span>
                </a>
            ))
        }
    </div>
</section>

<style>
    .webapps { padding: 4rem 0; }
    .section-header {
        display: flex;
        align-items: baseline;
        gap: 0.75rem;
        margin-bottom: 0.5rem;
    }
    .section-header h2 {
        margin: 0;
        font-size: 1.4rem;
        letter-spacing: -0.02em;
    }
    .tag {
        font-size: 0.72rem;
        font-weight: 600;
        color: var(--accent);
        background: rgba(201, 126, 58, 0.1);
        padding: 0.2rem 0.55rem;
        border-radius: 4px;
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }
    .subtitle {
        color: var(--text-secondary);
        margin: 0 0 1.5rem;
        font-size: 0.95rem;
    }
    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.25rem;
    }
    .card {
        padding: 1.5rem;
        border-radius: 12px;
        border: 1px solid var(--border);
        background: var(--bg-secondary);
        text-decoration: none;
        color: var(--text-primary);
        transition: all 0.2s ease;
        position: relative;
        overflow: hidden;
    }
    .card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, var(--accent), #e8b872);
        opacity: 0;
        transition: opacity 0.2s ease;
    }
    .card:hover {
        transform: translateY(-3px);
        border-color: var(--border-hover);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
    }
    .card:hover::before { opacity: 1; }
    .card h3 { margin: 0 0 0.4rem 0; font-size: 1.1rem; }
    .card p { margin: 0 0 0.75rem 0; color: var(--text-secondary); font-size: 0.92rem; }
    .link { font-weight: 600; font-size: 0.88rem; color: var(--accent); }
</style>
