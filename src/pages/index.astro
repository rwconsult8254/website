---
import Layout from "../layouts/Layout.astro";
import WebAppsSection from "../components/WebAppsSection.astro";
---

<Layout title="Roger Wibrew — Process Engineering & AI">
    <!-- Hero section with background graphic -->
    <section class="hero-section">
        <div class="hero-glow-1"></div>
        <div class="hero-glow-2"></div>

        <div class="hero-bg">
            <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
                <defs>
                    <pattern id="grid" width="48" height="48" patternUnits="userSpaceOnUse">
                        <path d="M 48 0 L 0 0 0 48" fill="none" stroke="rgba(201,126,58,0.025)" stroke-width="0.5"/>
                    </pattern>
                </defs>
                <rect width="100%" height="100%" fill="url(#grid)"/>
            </svg>
        </div>

        <div class="hero">
            <div class="hero-content">
                <p class="kicker">
                    <span class="kicker-line"></span>
                    Process Engineering &amp; Intelligent Systems
                </p>
                <h1>
                    Engineering Expertise Meets<br/>
                    <span class="accent-text">AI-Driven Insight</span>
                </h1>
                <p class="lede">
                    25 years of hands-on process operations and dynamic
                    simulation, combined with applied machine learning.
                </p>

                <div class="cta">
                    <a class="btn primary" href="/projects">View Projects</a>
                    <a class="btn" href="/blog">Read the Blog</a>
                    <a class="btn" href="/contact">Contact</a>
                </div>
            </div>

            <!-- Hero illustration: process + neural network diagram -->
            <div class="hero-visual">
                <svg class="hero-illustration" viewBox="0 0 420 370" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <!-- INLET PIPING -->
                    <line x1="15" y1="80" x2="118" y2="80" stroke="#c97e3a" stroke-width="1.8" opacity="0.55"/>
                    <line x1="118" y1="80" x2="118" y2="108" stroke="#c97e3a" stroke-width="1.8" opacity="0.55"/>
                    <line x1="15" y1="80" x2="118" y2="80" stroke="#dea054" stroke-width="1.8" opacity="0.2" class="flow-animated"/>
                    <polygon points="13,77 20,80 13,83" fill="#c97e3a" opacity="0.4"/>
                    <!-- FI-100 -->
                    <circle cx="66" cy="62" r="13" stroke="#c97e3a" stroke-width="1.1" fill="rgba(201,126,58,0.04)" opacity="0.7"/>
                    <line x1="66" y1="75" x2="66" y2="80" stroke="#c97e3a" stroke-width="0.8" opacity="0.45"/>
                    <text x="66" y="60" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="7.5" fill="#c97e3a" opacity="0.75" font-weight="500">FI</text>
                    <text x="66" y="68" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="5.5" fill="#c97e3a" opacity="0.45">100</text>
                    <!-- VESSEL -->
                    <rect x="88" y="108" width="60" height="148" rx="1" stroke="#c97e3a" stroke-width="2" fill="rgba(201,126,58,0.025)" opacity="0.75"/>
                    <path d="M88 113 Q118 92 148 113" stroke="#c97e3a" stroke-width="2" fill="none" opacity="0.75"/>
                    <path d="M88 251 Q118 272 148 251" stroke="#c97e3a" stroke-width="2" fill="none" opacity="0.75"/>
                    <rect x="90" y="172" width="56" height="79" fill="rgba(201,126,58,0.07)" rx="1"/>
                    <g class="level-surface">
                        <path d="M90 172 Q102 169 114 172 Q126 175 138 172 Q144 170 146 172" stroke="#c97e3a" stroke-width="1" fill="none" opacity="0.35"/>
                    </g>
                    <line x1="82" y1="125" x2="87" y2="125" stroke="#c97e3a" stroke-width="0.7" opacity="0.2"/>
                    <line x1="82" y1="155" x2="87" y2="155" stroke="#c97e3a" stroke-width="0.7" opacity="0.2"/>
                    <line x1="82" y1="185" x2="87" y2="185" stroke="#c97e3a" stroke-width="0.7" opacity="0.2"/>
                    <line x1="82" y1="215" x2="87" y2="215" stroke="#c97e3a" stroke-width="0.7" opacity="0.2"/>
                    <line x1="82" y1="245" x2="87" y2="245" stroke="#c97e3a" stroke-width="0.7" opacity="0.2"/>
                    <text x="79" y="128" text-anchor="end" font-family="JetBrains Mono,monospace" font-size="5" fill="#c97e3a" opacity="0.2">5</text>
                    <text x="79" y="188" text-anchor="end" font-family="JetBrains Mono,monospace" font-size="5" fill="#c97e3a" opacity="0.2">3</text>
                    <text x="79" y="248" text-anchor="end" font-family="JetBrains Mono,monospace" font-size="5" fill="#c97e3a" opacity="0.2">1</text>
                    <!-- TI-100 -->
                    <line x1="55" y1="200" x2="88" y2="200" stroke="#c97e3a" stroke-width="0.9" opacity="0.35"/>
                    <circle cx="40" cy="200" r="13" stroke="#c97e3a" stroke-width="1.1" fill="rgba(201,126,58,0.04)" opacity="0.65"/>
                    <text x="40" y="198" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="7.5" fill="#c97e3a" opacity="0.7" font-weight="500">TI</text>
                    <text x="40" y="206" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="5.5" fill="#c97e3a" opacity="0.45">100</text>
                    <!-- LT-100 -->
                    <line x1="148" y1="145" x2="170" y2="145" stroke="#c97e3a" stroke-width="0.9" opacity="0.35"/>
                    <line x1="148" y1="230" x2="170" y2="230" stroke="#c97e3a" stroke-width="0.9" opacity="0.35"/>
                    <line x1="170" y1="145" x2="170" y2="230" stroke="#c97e3a" stroke-width="0.9" opacity="0.35"/>
                    <circle cx="190" cy="187" r="13" stroke="#c97e3a" stroke-width="1.1" fill="rgba(201,126,58,0.04)" opacity="0.7"/>
                    <line x1="170" y1="187" x2="177" y2="187" stroke="#c97e3a" stroke-width="0.8" opacity="0.4"/>
                    <text x="190" y="185" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="7.5" fill="#c97e3a" opacity="0.75" font-weight="500">LT</text>
                    <text x="190" y="193" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="5.5" fill="#c97e3a" opacity="0.45">100</text>
                    <!-- Signal to controller -->
                    <line x1="203" y1="187" x2="248" y2="187" stroke="#c97e3a" stroke-width="0.9" opacity="0.3" stroke-dasharray="3 3"/>
                    <!-- LIC-100 Controller -->
                    <rect x="248" y="168" width="60" height="38" rx="5" stroke="#c97e3a" stroke-width="1.3" fill="rgba(201,126,58,0.035)" opacity="0.7"/>
                    <line x1="248" y1="179" x2="308" y2="179" stroke="#c97e3a" stroke-width="0.5" opacity="0.25"/>
                    <text x="278" y="176" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="7.5" fill="#c97e3a" opacity="0.75" font-weight="500">LIC</text>
                    <text x="278" y="196" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="5.5" fill="#c97e3a" opacity="0.45">100</text>
                    <text x="264" y="189" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="4.5" fill="#6882a8" opacity="0.5">SP 2.5</text>
                    <text x="294" y="189" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="4.5" fill="#c97e3a" opacity="0.4">PV 2.4</text>
                    <!-- Signal to valve -->
                    <line x1="278" y1="206" x2="278" y2="282" stroke="#c97e3a" stroke-width="0.9" opacity="0.3" stroke-dasharray="3 3"/>
                    <line x1="278" y1="282" x2="235" y2="282" stroke="#c97e3a" stroke-width="0.9" opacity="0.3" stroke-dasharray="3 3"/>
                    <!-- Outlet piping -->
                    <line x1="118" y1="264" x2="118" y2="282" stroke="#c97e3a" stroke-width="1.8" opacity="0.55"/>
                    <line x1="118" y1="282" x2="196" y2="282" stroke="#c97e3a" stroke-width="1.8" opacity="0.55"/>
                    <line x1="118" y1="282" x2="196" y2="282" stroke="#dea054" stroke-width="1.8" opacity="0.2" class="flow-animated"/>
                    <!-- Control valve -->
                    <polygon points="198,270 218,282 198,294" stroke="#c97e3a" stroke-width="1.4" fill="rgba(201,126,58,0.05)" opacity="0.7"/>
                    <polygon points="238,270 218,282 238,294" stroke="#c97e3a" stroke-width="1.4" fill="rgba(201,126,58,0.05)" opacity="0.7"/>
                    <line x1="218" y1="262" x2="218" y2="270" stroke="#c97e3a" stroke-width="1.2" opacity="0.5"/>
                    <rect x="211" y="252" width="14" height="10" rx="1" stroke="#c97e3a" stroke-width="1" fill="rgba(201,126,58,0.035)" opacity="0.5"/>
                    <!-- Post-valve pipe -->
                    <line x1="238" y1="282" x2="340" y2="282" stroke="#c97e3a" stroke-width="1.8" opacity="0.55"/>
                    <line x1="238" y1="282" x2="340" y2="282" stroke="#dea054" stroke-width="1.8" opacity="0.2" class="flow-animated"/>
                    <!-- FI-101 -->
                    <circle cx="305" cy="264" r="13" stroke="#c97e3a" stroke-width="1.1" fill="rgba(201,126,58,0.04)" opacity="0.7"/>
                    <line x1="305" y1="277" x2="305" y2="282" stroke="#c97e3a" stroke-width="0.8" opacity="0.45"/>
                    <text x="305" y="262" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="7.5" fill="#c97e3a" opacity="0.75" font-weight="500">FI</text>
                    <text x="305" y="270" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="5.5" fill="#c97e3a" opacity="0.45">101</text>
                    <!-- Pump -->
                    <circle cx="368" cy="282" r="14" stroke="#c97e3a" stroke-width="1.4" fill="rgba(201,126,58,0.025)" opacity="0.55"/>
                    <line x1="368" y1="268" x2="368" y2="248" stroke="#c97e3a" stroke-width="1.8" opacity="0.5"/>
                    <polygon points="363,250 368,242 373,250" fill="#c97e3a" opacity="0.35"/>
                    <text x="380" y="246" font-family="JetBrains Mono,monospace" font-size="5" fill="#c97e3a" opacity="0.25">TO HEADER</text>
                    <!-- AI trend overlay -->
                    <rect x="318" y="322" width="86" height="38" rx="4" stroke="#6882a8" stroke-width="0.8" fill="rgba(104,130,168,0.025)" opacity="0.5"/>
                    <text x="326" y="333" font-family="JetBrains Mono,monospace" font-size="5" fill="#6882a8" opacity="0.45" font-weight="500">TREND · LIC-100</text>
                    <polyline points="326,352 336,347 346,350 356,342 366,345 376,338 386,341 396,336" stroke="#6882a8" stroke-width="1" fill="none" opacity="0.4"/>
                    <line x1="326" y1="344" x2="396" y2="344" stroke="#c97e3a" stroke-width="0.6" opacity="0.2" stroke-dasharray="2 2"/>
                    <line x1="308" y1="195" x2="335" y2="195" stroke="#6882a8" stroke-width="0.6" opacity="0.18" stroke-dasharray="2 3"/>
                    <line x1="335" y1="195" x2="335" y2="322" stroke="#6882a8" stroke-width="0.6" opacity="0.18" stroke-dasharray="2 3"/>
                </svg>
            </div>
        </div>
    </section>

    <!-- Disciplines bar -->
    <section class="disciplines">
        <div class="disciplines-inner">
            <div class="discipline">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2v8L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45L14 10V2"/><line x1="8.5" y1="2" x2="15.5" y2="2"/><line x1="7" y1="16" x2="17" y2="16"/></svg>
                Process Simulation
            </div>
            <div class="discipline">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
                Dynamic Modeling
            </div>
            <div class="discipline">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/><path d="M7 8h2M7 12h4"/></svg>
                Machine Learning
            </div>
            <div class="discipline">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                Engineering Software
            </div>
        </div>
    </section>

    <div class="container">
        <WebAppsSection />

        <section class="work-with-me">
            <div class="work-cta-box">
                <div>
                    <h2>Work With Me</h2>
                    <p>
                        I'm always open to interesting conversations — whether that's collaborating on a project,
                        exploring an idea, or just talking shop about process engineering and ML.
                    </p>
                </div>
                <a class="btn primary" href="/contact">Get in Touch</a>
            </div>
        </section>

        <section class="grid">
            <article class="card">
                <div class="card-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                </div>
                <h2>Projects & Apps</h2>
                <p>
                    Small, focused tools that demonstrate modeling assumptions,
                    implementation choices, and usable outputs.
                </p>
                <a href="/projects">Explore projects &rarr;</a>
            </article>

            <article class="card">
                <div class="card-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z"/></svg>
                </div>
                <h2>Writing</h2>
                <p>
                    Technical articles focused on solving real-life
                    engineering problems with AI.
                </p>
                <a href="/blog">Browse posts &rarr;</a>
            </article>

            <article class="card">
                <div class="card-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="5"/><path d="M20 21a8 8 0 0 0-16 0"/></svg>
                </div>
                <h2>About</h2>
                <p>
                    My background, practical experience, and approach to
                    combining engineering with ML.
                </p>
                <a href="/about">Read more &rarr;</a>
            </article>
        </section>
    </div>
</Layout>

<style>
    .hero-section {
        position: relative;
        overflow: hidden;
        border-bottom: 1px solid var(--border);
    }
    .hero-bg {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 0;
    }
    .hero-bg svg { width: 100%; height: 100%; }
    .hero-glow-1 {
        position: absolute;
        top: -80px;
        left: -120px;
        width: 520px;
        height: 520px;
        background: radial-gradient(circle, rgba(201, 126, 58, 0.06) 0%, transparent 65%);
        pointer-events: none;
    }
    .hero-glow-2 {
        position: absolute;
        bottom: -60px;
        right: -80px;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(104, 130, 168, 0.04) 0%, transparent 65%);
        pointer-events: none;
    }
    .hero {
        position: relative;
        z-index: 1;
        max-width: 1040px;
        margin: 0 auto;
        padding: 5rem 1.5rem 4.5rem;
        display: grid;
        grid-template-columns: 1fr 420px;
        gap: 3rem;
        align-items: center;
    }
    .hero-content { max-width: 600px; }

    .kicker {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--accent);
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        margin: 0 0 1rem;
    }
    .kicker-line {
        width: 32px;
        height: 2px;
        background: var(--accent);
        border-radius: 1px;
    }
    h1 {
        font-size: clamp(2.2rem, 4.5vw, 3.2rem);
        line-height: 1.08;
        margin: 0 0 1.25rem;
        letter-spacing: -0.03em;
        font-weight: 800;
    }
    h1 .accent-text {
        background: linear-gradient(135deg, var(--accent) 0%, var(--accent-hover) 60%, #e8b872 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
    .lede {
        font-size: 1.1rem;
        line-height: 1.7;
        max-width: 56ch;
        margin: 0 0 2rem;
        color: var(--text-secondary);
    }

    .cta { display: flex; gap: 0.75rem; flex-wrap: wrap; }
    .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.65rem 1.35rem;
        border-radius: 8px;
        border: 1px solid var(--border);
        text-decoration: none;
        color: var(--text-secondary);
        font-size: 0.9rem;
        font-weight: 600;
        transition: all 0.2s ease;
    }
    .btn:hover {
        border-color: var(--border-hover);
        color: var(--text-primary);
        background: var(--bg-surface);
    }
    .btn.primary {
        background: var(--accent);
        border-color: var(--accent);
        color: #0b0d12;
    }
    .btn.primary:hover {
        background: var(--accent-hover);
        border-color: var(--accent-hover);
        box-shadow: 0 0 24px rgba(201, 126, 58, 0.2);
    }

    .hero-visual {
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .hero-illustration { width: 100%; max-width: 420px; }

    @keyframes flow-dash { to { stroke-dashoffset: -12; } }
    @keyframes level-bob { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-3px); } }
    :global(.flow-animated) { stroke-dasharray: 6 6; animation: flow-dash 1.5s linear infinite; }
    :global(.level-surface) { animation: level-bob 4s ease-in-out infinite; }

    .disciplines {
        border-bottom: 1px solid var(--border);
        background: var(--bg-secondary);
    }
    .disciplines-inner {
        max-width: 1040px;
        margin: 0 auto;
        padding: 1.25rem 1.5rem;
        display: flex;
        justify-content: center;
        gap: 2.5rem;
        flex-wrap: wrap;
    }
    .discipline {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--text-secondary);
        font-size: 0.88rem;
        font-weight: 500;
    }
    .discipline svg { width: 18px; height: 18px; color: var(--accent); flex-shrink: 0; }

    .container {
        max-width: 1040px;
        margin: 0 auto;
        padding: 0 1.5rem;
    }

    .work-with-me { padding: 2.5rem 0; }
    .work-cta-box {
        padding: 2rem 2.25rem;
        border: 1px solid var(--border);
        border-radius: 16px;
        background: linear-gradient(135deg, var(--bg-secondary) 0%, rgba(201, 126, 58, 0.03) 100%);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2rem;
        flex-wrap: wrap;
    }
    .work-cta-box h2 { margin: 0 0 0.4rem; font-size: 1.3rem; }
    .work-cta-box p {
        color: var(--text-secondary);
        max-width: 52ch;
        margin: 0;
        font-size: 0.95rem;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.25rem;
        padding: 2.5rem 0 4rem;
    }
    .card {
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.75rem;
        background: var(--bg-secondary);
        transition: all 0.2s ease;
    }
    .card:hover {
        border-color: var(--border-hover);
        transform: translateY(-3px);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
    }
    .card-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        background: rgba(201, 126, 58, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
    }
    .card-icon svg { width: 20px; height: 20px; color: var(--accent); }
    .card h2 { margin: 0 0 0.5rem; font-size: 1.15rem; letter-spacing: -0.01em; }
    .card p { margin: 0 0 1rem; color: var(--text-secondary); font-size: 0.92rem; }
    .card a { font-size: 0.88rem; font-weight: 600; text-decoration: none; }

    @media (max-width: 860px) {
        .hero { grid-template-columns: 1fr; padding: 3.5rem 1.5rem 3rem; }
        .hero-visual { display: none; }
        .grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 640px) {
        .disciplines-inner { gap: 1.5rem; }
        .work-cta-box { flex-direction: column; align-items: flex-start; }
    }
</style>
