---
import Layout from "../layouts/Layout.astro";
import WebAppsSection from "../components/WebAppsSection.astro";
---

<Layout title="Roger Wibrew — Chemical Engineering & AI">
    <main class="container">
        <section class="hero">
            <p class="kicker">
                Chemical Engineer • Process Simulation • AI-Enabled Engineering
                Tools
            </p>
            <h1>
                Combining Traditional Chemical Engineering with Modern AI Tools.
            </h1>
            <p class="lede">
                I combine hands-on chemical engineering experience with modern
                AI and machine-learning methods to improve how chemical
                processes operate. My focus is on practical simulations and
                data-informed models that help drive efficiency, cut costs, and
                reduce emissions.
            </p>

            <div class="cta">
                <a class="btn primary" href="/projects">View Projects</a>
                <a class="btn" href="/blog">Read the Blog</a>
                <a class="btn" href="/contact">Contact</a>
            </div>
        </section>

        <WebAppsSection />

        <section class="grid">
            <article class="card">
                <h2>Projects & Apps</h2>
                <p>
                    Small, focused tools that demonstrate modeling assumptions,
                    implementation choices, and usable outputs.
                </p>
                <a href="/projects">Explore projects →</a>
            </article>

            <article class="card">
                <h2>Writing</h2>
                <p>
                    Technical articles on simulation, tank dynamics,
                    thermodynamics, and practical AI workflows.
                </p>
                <a href="/blog">Browse posts →</a>
            </article>

            <article class="card">
                <h2>About</h2>
                <p>
                    My background, interests, and the direction I’m building
                    toward: consulting and contract work.
                </p>
                <a href="/about">Read more →</a>
            </article>
        </section>
    </main>
</Layout>

<style>
    .container {
        max-width: 980px;
        margin: 0 auto;
        padding: 4rem 1.25rem;
    }
    .hero {
        padding: 1rem 0 2.5rem;
    }
    .kicker {
        opacity: 0.8;
        margin: 0 0 0.75rem;
    }
    h1 {
        font-size: clamp(2.2rem, 4vw, 3.2rem);
        line-height: 1.1;
        margin: 0 0 1rem;
    }
    .lede {
        font-size: 1.1rem;
        line-height: 1.6;
        max-width: 70ch;
        margin: 0 0 1.5rem;
        opacity: 0.95;
    }

    .cta {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }
    .btn {
        display: inline-block;
        padding: 0.7rem 1rem;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.18);
        text-decoration: none;
    }
    .btn.primary {
        border-color: rgba(255, 255, 255, 0.35);
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 1rem;
        margin-top: 2rem;
    }
    .card {
        grid-column: span 12;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 16px;
        padding: 1.25rem;
        background: rgba(255, 255, 255, 0.03);
    }
    .card h2 {
        margin: 0 0 0.5rem;
        font-size: 1.2rem;
    }
    .card p {
        margin: 0 0 0.75rem;
        opacity: 0.9;
    }
    .card a {
        text-decoration: none;
    }

    @media (min-width: 800px) {
        .card {
            grid-column: span 4;
        }
    }
</style>
