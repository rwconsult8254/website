---
import Layout from "../layouts/Layout.astro";
import WebAppsSection from "../components/WebAppsSection.astro";
---

<Layout title="Roger Wibrew — Chemical Engineering & AI">
    <main class="container">
        <section class="hero">
            <p class="kicker">
                Chemical Engineer &middot; Process Simulation &middot; AI-Enabled Engineering Tools
            </p>
            <h1>
                Combining Traditional Chemical Engineering with Modern AI Tools.
            </h1>
            <p class="lede">
                I combine hands-on chemical engineering experience with modern
                AI and machine-learning methods to improve how chemical
                processes operate. My focus is on practical simulations and
                data-informed models that help drive efficiency, cut costs, and
                reduce emissions.
            </p>

            <div class="cta">
                <a class="btn primary" href="/projects">View Projects</a>
                <a class="btn" href="/blog">Read the Blog</a>
                <a class="btn" href="/contact">Contact</a>
            </div>
        </section>

        <WebAppsSection />

        <section class="work-with-me">
            <h2>Work With Me</h2>
            <p>
                I'm always open to interesting conversations — whether that's collaborating on a project,
                exploring an idea, or just talking shop about process engineering and ML.
            </p>
            <a class="btn primary" href="/contact">Get in touch</a>
        </section>

        <section class="grid">
            <article class="card">
                <h2>Projects & Apps</h2>
                <p>
                    Small, focused tools that demonstrate modeling assumptions,
                    implementation choices, and usable outputs.
                </p>
                <a href="/projects">Explore projects &rarr;</a>
            </article>

            <article class="card">
                <h2>Writing</h2>
                <p>
                    Technical articles on simulation, tank dynamics,
                    thermodynamics, and practical AI workflows.
                </p>
                <a href="/blog">Browse posts &rarr;</a>
            </article>

            <article class="card">
                <h2>About</h2>
                <p>
                    My background, practical experience, and approach to
                    combining engineering with ML.
                </p>
                <a href="/about">Read more &rarr;</a>
            </article>
        </section>
    </main>
</Layout>

<style>
    .container {
        max-width: 980px;
        margin: 0 auto;
        padding: 4rem 1.25rem;
    }
    .hero {
        padding: 1rem 0 2.5rem;
    }
    .kicker {
        color: var(--accent);
        font-size: 0.9rem;
        font-weight: 500;
        letter-spacing: 0.02em;
        margin: 0 0 0.75rem;
    }
    h1 {
        font-size: clamp(2rem, 4vw, 3rem);
        line-height: 1.1;
        margin: 0 0 1.25rem;
        letter-spacing: -0.02em;
    }
    .lede {
        font-size: 1.1rem;
        line-height: 1.65;
        max-width: 65ch;
        margin: 0 0 1.75rem;
        color: var(--text-secondary);
    }

    .cta {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }
    .btn {
        display: inline-block;
        padding: 0.6rem 1.25rem;
        border-radius: 8px;
        border: 1px solid var(--border);
        text-decoration: none;
        color: var(--text-secondary);
        font-size: 0.9rem;
        font-weight: 500;
        transition: all 0.15s ease;
    }
    .btn:hover {
        border-color: var(--border-hover);
        color: var(--text-primary);
        background: var(--bg-surface);
    }
    .btn.primary {
        background: var(--accent);
        border-color: var(--accent);
        color: #fff;
    }
    .btn.primary:hover {
        background: var(--accent-hover);
        border-color: var(--accent-hover);
    }

    .work-with-me {
        margin-top: 4rem;
        padding: 1.5rem;
        border: 1px solid var(--border);
        border-radius: 12px;
        background: var(--bg-secondary);
    }
    .work-with-me h2 {
        margin: 0 0 0.5rem;
        font-size: 1.3rem;
    }
    .work-with-me p {
        color: var(--text-secondary);
        max-width: 60ch;
        margin: 0 0 1.25rem;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 1rem;
        margin-top: 2rem;
    }
    .card {
        grid-column: span 12;
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.5rem;
        background: var(--bg-secondary);
        transition: border-color 0.15s ease;
    }
    .card:hover {
        border-color: var(--border-hover);
    }
    .card h2 {
        margin: 0 0 0.5rem;
        font-size: 1.15rem;
    }
    .card p {
        margin: 0 0 0.75rem;
        color: var(--text-secondary);
        font-size: 0.95rem;
    }
    .card a {
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
    }

    @media (min-width: 800px) {
        .card {
            grid-column: span 4;
        }
    }
</style>
