---
import Layout from "../layouts/Layout.astro";

const projects = [
    {
        title: "Tank Dynamics Simulator",
        summary:
            "A first-principles dynamic model with interactive parameters and plots. Part 1 in a series.",
        links: [
            {
                label: "Write-up",
                href: "/blog/tank-dynamics-simulation-part-1",
            },
            { label: "Demo", href: "#" },
            { label: "GitHub", href: "#" },
        ],
    },
    {
        title: "Simple Process Thermodynamics Explorer",
        summary:
            "A lightweight tool for sanity-checking thermodynamic relationships in simple process simulations.",
        links: [
            {
                label: "Write-up",
                href: "/blog/thermodynamics-behind-simple-process-simulation",
            },
            { label: "Demo", href: "#" },
            { label: "GitHub", href: "#" },
        ],
    },
];
---

<Layout title="Projects — Roger Wibrew">
    <main class="container">
        <header class="head">
            <h1>Projects & Technical Apps</h1>
            <p>
                Focused tools and simulations demonstrating modeling
                assumptions, implementation choices, and usable outputs.
            </p>
        </header>

        <section class="list">
            {
                projects.map((p) => (
                    <article class="card">
                        <h2>{p.title}</h2>
                        <p>{p.summary}</p>
                        <div class="links">
                            {p.links.map((l) => (
                                <a href={l.href}>{l.label}</a>
                            ))}
                        </div>
                    </article>
                ))
            }
        </section>
    </main>

    <style>
        .container {
            max-width: 980px;
            margin: 0 auto;
            padding: 3rem 1.25rem;
        }
        .head p {
            opacity: 0.9;
            max-width: 75ch;
        }
        .list {
            display: grid;
            gap: 1rem;
            margin-top: 1.5rem;
        }
        .card {
            border: 1px solid rgba(255, 255, 255, 0.12);
            border-radius: 16px;
            padding: 1.25rem;
            background: rgba(255, 255, 255, 0.03);
        }
        .card h2 {
            margin: 0 0 0.5rem;
        }
        .links {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
            margin-top: 0.75rem;
        }
        .links a {
            text-decoration: none;
            border-bottom: 1px solid rgba(255, 255, 255, 0.25);
        }
    </style>
</Layout>
