---
import Layout from "../layouts/Layout.astro";

const projects = [
    {
        title: "Tank Dynamics Simulator",
        summary:
            "A first-principles dynamic model with interactive parameters and plots. Part 1 in a series.",
        links: [
            {
                label: "Write-up",
                href: "/blog/tank-dynamics-simulation-part-1",
            },
        ],
    },
];
---

<Layout title="Projects — Roger Wibrew">
    <main class="container">
        <header class="head">
            <h1>Projects & Technical Apps</h1>
            <p>
                Focused tools and simulations demonstrating modeling
                assumptions, implementation choices, and usable outputs.
            </p>
        </header>

        <section class="list">
            {
                projects.map((p) => (
                    <article class="card">
                        <h2>{p.title}</h2>
                        <p>{p.summary}</p>
                        <div class="links">
                            {p.links.map((l) => (
                                <a href={l.href}>{l.label}</a>
                            ))}
                        </div>
                    </article>
                ))
            }
        </section>
    </main>

    <style>
        .container {
            max-width: 980px;
            margin: 0 auto;
            padding: 3rem 1.25rem;
        }
        .head p {
            color: var(--text-secondary);
            max-width: 65ch;
        }
        .list {
            display: grid;
            gap: 1rem;
            margin-top: 1.5rem;
        }
        .card {
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 1.5rem;
            background: var(--bg-secondary);
            transition: border-color 0.15s ease;
        }
        .card:hover {
            border-color: var(--border-hover);
        }
        .card h2 {
            margin: 0 0 0.5rem;
            font-size: 1.2rem;
        }
        .card p {
            color: var(--text-secondary);
            font-size: 0.95rem;
        }
        .links {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
            margin-top: 0.75rem;
        }
        .links a {
            text-decoration: none;
            font-weight: 500;
            font-size: 0.9rem;
        }
    </style>
</Layout>
