---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Tank Simulation — Roger Wibrew">
    <main class="container">
        <h1>Tank Dynamics Simulator</h1>
        <p>
            A real-time SCADA-style interface for a first-principles tank level
            control simulation with PID feedback.
        </p>
        <a class="launch" href="https://tank.rogerwibrew.com">
            Launch Simulator &rarr;
        </a>
        <a href="/projects">&larr; Back to projects</a>
    </main>

    <style>
        .container {
            max-width: 720px;
            margin: 0 auto;
            padding: 3rem 1.25rem;
        }
        p {
            color: var(--text-secondary);
            max-width: 55ch;
        }
        .launch {
            display: inline-block;
            margin: 1.5rem 0;
            padding: 0.75rem 1.5rem;
            background: var(--accent);
            color: var(--bg-primary);
            border-radius: 8px;
            text-decoration: none;
            font-weight: 600;
            transition: opacity 0.15s ease;
        }
        .launch:hover {
            opacity: 0.85;
        }
        a:last-child {
            display: block;
            font-size: 0.9rem;
        }
    </style>
</Layout>
