---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import Layout from './Layout.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate } = Astro.props;
---

<Layout title={`${title} — Roger Wibrew`} description={description}>
	<article class="post">
		<header class="post-header">
			<div class="date">
				<FormattedDate date={pubDate} />
				{
					updatedDate && (
						<span class="updated">
							(Updated <FormattedDate date={updatedDate} />)
						</span>
					)
				}
			</div>
			<h1>{title}</h1>
		</header>
		<div class="prose">
			<slot />
		</div>
	</article>

	<style>
		.post {
			max-width: 720px;
			margin: 0 auto;
			padding: 3rem 1.25rem;
		}
		.post-header {
			margin-bottom: 2rem;
			border-bottom: 1px solid rgba(255, 255, 255, 0.1);
			padding-bottom: 1.5rem;
		}
		.post-header h1 {
			font-size: clamp(1.8rem, 3.5vw, 2.4rem);
			line-height: 1.15;
			margin: 0.5rem 0 0;
		}
		.date {
			opacity: 0.7;
			font-size: 0.9rem;
		}
		.updated {
			font-style: italic;
		}
		.prose {
			line-height: 1.75;
		}
		.prose :global(h2) {
			margin-top: 2rem;
		}
		.prose :global(pre) {
			padding: 1rem;
			border-radius: 8px;
			overflow-x: auto;
		}
		.prose :global(code) {
			font-size: 0.9em;
		}
		.prose :global(a) {
			text-decoration: underline;
			text-underline-offset: 2px;
		}
	</style>
</Layout>
